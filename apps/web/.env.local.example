# AI Provider Keys
# Add your keys here if you want to use them as server-side defaults 
# instead of having users paste them in the frontend.

# OpenRouter (Llama 3, DeepSeek, Gemini Flash free variants)
# OPENROUTER_API_KEY=sk-or-v1-...

# Groq (Llama 3, Gemma)
# GROQ_API_KEY=gsk_...

# Cerebras (Llama 3.1)
# CEREBRAS_API_KEY=...
